{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "TripbookMedia",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject", "s3:DeleteObject"],
      "Resource": "arn:aws:s3:::tripbook-media-416369639144/*"
    },
    {
      "Sid": "TripbookBucket",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::tripbook-media-416369639144"
    },
    {
      "Sid": "TripbookEmail",
      "Effect": "Allow",
      "Action": ["ses:SendEmail"],
      "Resource": "*"
    }
  ]
}
